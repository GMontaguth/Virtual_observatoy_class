<PARAM arraysize="350" datatype="char" name="QUERY" value='SELECT TOP 30000   RA_ICRS, DE_ICRS,   "uPmag", "gPmag", "rPmag", "iPmag", "zPmag",   "e_uPmag", "e_gPmag", "e_rPmag", "e_iPmag", "e_zPmag",   zsp, e_zsp, spCl FROM "V/154/sdss16" WHERE RA_ICRS BETWEEN 320 AND 340   AND DE_ICRS BETWEEN -1.25 AND 1.25   AND spCl = &apos;GALAXY&apos;   AND zsp &gt; 0.02 AND zsp &lt; 0.2   AND f_zsp = 0   AND mode = 1   AND clean = 1'/>
